
# DATABASE CONFIGURATION (Prisma / Neon / Vercel Postgres)
## Main connection string (Recommended for most uses with pooling)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
## Direct connection string (For migrations or uses requiring no pgbouncer)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
## Individual Connection Parameters
PGHOST="your-database-host"
PGUSER="your-database-user"
PGDATABASE="your-database-name"
PGPASSWORD="your-database-password"
## Vercel Postgres / Neon Templates Compatibility
POSTGRES_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
POSTGRES_USER="your-database-user"
POSTGRES_HOST="your-database-host"
POSTGRES_PASSWORD="your-database-password"
POSTGRES_DATABASE="your-database-name"


# AUTHENTICATION
## Secret key for JWT signing and verification
JWT_SECRET="your_super_secret_random_string_here"


# APPLICATION SETTINGS
## Optional: Base URL for the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"